# ---------------------------------------------------------------------------
# Settl environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Slack app credentials ---------------------------------------------------
# Bot User OAuth Token — used for all Web API calls (chat.postMessage, etc.)
# Leave blank when using `slack run`; the CLI injects a real token automatically.
SLACK_BOT_TOKEN=

# App-Level Token (connections:write scope) — required for Socket Mode.
# Leave blank when using `slack run`; the CLI injects a real token automatically.
SLACK_APP_TOKEN=

# Signing secret — verifies that inbound requests originate from Slack.
SLACK_SIGNING_SECRET=...

# --- Splitwise MCP integration ----------------------------------------------
# OAuth 2.0 app credentials from your Splitwise developer account.
SPLITWISE_CONSUMER_KEY=...
SPLITWISE_CONSUMER_SECRET=...

# URL of the running Splitwise MCP server (local dev or deployed).
SPLITWISE_MCP_URL=http://localhost:8000

# --- Real-Time Search API ----------------------------------------------------
# API key used to fetch live FX rates for multi-currency expense groups.
RTS_API_KEY=...

# --- App configuration -------------------------------------------------------
# Socket Mode avoids the need for a public HTTP endpoint during local dev.
# Set to "false" to run in HTTP mode (requires ngrok + request URL).
SLACK_SOCKET_MODE=true

# Port used when running in HTTP mode (ignored when Socket Mode is enabled).
PORT=3000

# Default currency assumed when an expense omits an explicit currency.
DEFAULT_BASE_CURRENCY=USD

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
