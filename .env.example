# ---------------------------------------------------------------------------
# Settl environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Slack app credentials ---------------------------------------------------
# Bot User OAuth Token — used for all Web API calls (chat.postMessage, etc.)
# Leave blank when using `slack run`; the CLI injects a real token automatically.
SLACK_BOT_TOKEN=

# App-Level Token (connections:write scope) — required for Socket Mode.
# Leave blank when using `slack run`; the CLI injects a real token automatically.
SLACK_APP_TOKEN=

# Signing secret — verifies that inbound requests originate from Slack.
SLACK_SIGNING_SECRET=...

# --- Splitwise MCP integration ----------------------------------------------
# OAuth 2.0 app credentials from your Splitwise developer account.
SPLITWISE_CONSUMER_KEY=...
SPLITWISE_CONSUMER_SECRET=...

# URL of the running Splitwise MCP server (optional — friend/group resolution tools).
SPLITWISE_MCP_URL=http://localhost:8000

# OAuth redirect URI registered in your Splitwise app settings.
SPLITWISE_REDIRECT_URI=http://localhost:3000/oauth/splitwise/callback

# --- Slack AI parsing (natural-language expense understanding) ---------------
# Provide ONE of the following to enable AI parsing. If none is set, Settl
# falls back to a regex parser so the app still works with zero configuration.
# Providers are tried in this order: NVIDIA -> OpenAI -> Anthropic.

# NVIDIA build (build.nvidia.com / NIM) — OpenAI-compatible API.
NVIDIA_API_KEY=
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Currency conversion -----------------------------------------------------
# Frankfurter API base URL (ECB rates, no key required). Override if needed.
FX_API_BASE=https://api.frankfurter.app

# --- Nudge agent -------------------------------------------------------------
# Minimum total outstanding debt before a nudge fires (in group base currency).
NUDGE_OUTSTANDING_THRESHOLD=50
# Also nudge when the oldest unsettled share exceeds this many days.
NUDGE_AGE_THRESHOLD_DAYS=3

# --- App configuration -------------------------------------------------------
# Socket Mode avoids the need for a public HTTP endpoint during local dev.
# Set to "false" to run in HTTP mode (requires ngrok + request URL).
SLACK_SOCKET_MODE=true

# Port used when running in HTTP mode (ignored when Socket Mode is enabled).
PORT=3000

# Default currency assumed when an expense omits an explicit currency.
DEFAULT_BASE_CURRENCY=USD

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
